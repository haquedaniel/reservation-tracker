{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Weekly email (dry run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
            "--mode", "weekly-email",
            "--dry-run",
            "--source", "google-sheets"
            ]
        },

        {
            "name": "Send weekly email",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": ["--mode", "weekly-email"]
        },

        {
            "name": "Custom paths",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--mode", "weekly-email",
                "--dry-run",
                "--input", "Reservations.xlsm",
                "--output", "output"
            ]
        }
    ]
}